# Production environment template — copy and fill in actual values
PORT=3001
NODE_ENV=production
DATABASE_URL=./production.db

# Set to 'false' for production (true only for demo events)
DEMO_MODE=false

# Python agent service URL — defaults to local if not set
# For public demo: leave empty to trigger deterministic fallback
AGENT_SERVICE_URL=

# LLM keys (server-side only, never exposed to frontend)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Fetch.ai agent credentials (optional)
FETCHAI_API_KEY=
FETCHAI_AGENT_ADDRESS=
