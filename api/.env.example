# ── Core ──────────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=./dev.db
NODE_ENV=development
DEMO_MODE=true

# ── Python agent service ───────────────────────────────────────────────────────
# Points to the Python process that runs analysis (Fetch.ai agent or local stub).
AGENT_SERVICE_URL=http://localhost:8000

# ── Fetch.ai / Agentverse ──────────────────────────────────────────────────────
# 1. Create an account at https://agentverse.ai
# 2. Create a new Hosted Agent, deploy the code in agent/
# 3. Copy the agent's bech32 address (agent1q...) into FETCHAI_AGENT_ADDRESS
# 4. Generate an API key in Agentverse → Settings → API Keys
FETCHAI_API_KEY=
FETCHAI_AGENT_ADDRESS=

# ── Browser Use ───────────────────────────────────────────────────────────────
# Browser Use (https://github.com/browser-use/browser-use) runs inside the
# Python agent and drives a Playwright browser with an LLM.
# Provide ONE of the following LLM keys:
ANTHROPIC_API_KEY=       # Preferred — Claude drives the browser
OPENAI_API_KEY=          # Alternative
